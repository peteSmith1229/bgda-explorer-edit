<UserControl x:Class="WorldExplorer.SkeletonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hvd="http://helix-toolkit.org/wpf"
             xmlns:local="clr-namespace:WorldExplorer"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:SkeletonViewModel}"
             d:DesignHeight="300" d:DesignWidth="300" DataContext="{Binding}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Grid.Column="0" Name="playButton" Content="{Binding PlayButtonLabel}"
                Click="playButton_Click" Padding="8,2" MinWidth="80" />
        <Slider Grid.Column="1" Name="frameSlider" Minimum="-1" Maximum="{Binding MaximumFrame}"
                Value="{Binding CurrentFrame}" VerticalAlignment="Center" />
        <Label Grid.Column="2" Content="{Binding CurrentFrame}" />
        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="Transparent" Name="trackballSource">
            <hvd:HelixViewport3D ClipToBounds="True" Name="viewport" IsChangeFieldOfViewEnabled="False">
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <AmbientLight Color="#808080" />
                    </ModelVisual3D.Content>
                </ModelVisual3D>
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <DirectionalLight Color="#FFFFFF" Direction="0, -1, -1" />
                    </ModelVisual3D.Content>
                </ModelVisual3D>
                <ModelVisual3D Content="{Binding Model}" />
            </hvd:HelixViewport3D>
        </Border>
    </Grid>
</UserControl>